generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  PAID
  CHECKING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum BalanceTransactionType {
  DEPOSIT
  WITHDRAWAL
  PURCHASE
  REFERRAL
  TRANSFER_SENT
  TRANSFER_RECEIVED
  REFUND
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum CheatStatusEnum {
  SAFE
  RISKY
  DANGER
  UPDATING
}

enum Platform {
  Android_NoRoot
  Android_Root
  iOS
  Panel
}

enum TariffName {
  DAY_1
  DAY_3
  DAY_7
  DAY_30
  DAY_60
}

model User {
  id              String   @id @default(cuid()) @db.VarChar(255)
  tgId            String?  @unique @db.VarChar(255)
  tgUsername      String?  @db.VarChar(255)
  firstName       String?  @db.VarChar(255)
  lastName        String?  @db.VarChar(255)
  balance         Decimal  @default(0) @db.Decimal(12, 2)
  referralCode    String?  @unique @db.VarChar(255)
  referralPercent Int      @default(5)
  isBlocked       Boolean  @default(false)
  blockReason     String?  @db.VarChar(255)
  /// Admin status is now determined by checking tgId against ADMIN_TELEGRAM_IDS env var
  isAdmin         Boolean  @default(false)
  roleId          String?  @db.VarChar(255)
  role            AdminRole?           @relation(fields: [roleId], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  sessions             Session[]
  orders               Order[]
  balanceTransactions  BalanceTransaction[]
  sentTransfers        BalanceTransaction[]   @relation("TransferSent")
  receivedTransfers    BalanceTransaction[]   @relation("TransferReceived")
  payments             Payment[]
  referralsMade        Referral[]             @relation("Referrer")
  referralsReceived    Referral[]             @relation("Referred")
  reviews              Review[]
  supportTickets       SupportTicket[]
  ticketMessages       TicketMessage[]
  favoriteProducts     FavoriteProduct[]
  auditLogs            AuditLog[]

  @@index([tgId])
  @@index([referralCode])
  @@map("users")
}

model AdminRole {
  id          String  @id @default(cuid()) @db.VarChar(255)
  name        String  @db.VarChar(255)
  permissions Json    @default("[]")

  users User[]

  @@map("admin_roles")
}

model Session {
  id        String   @id @default(cuid()) @db.VarChar(255)
  userId    String   @db.VarChar(255)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Category {
  id          String     @id @default(cuid()) @db.VarChar(255)
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?    @db.Text
  parentId    String?    @db.VarChar(255)
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  sortOrder   Int        @default(0)
  icon        String?    @db.VarChar(255)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid()) @db.VarChar(255)
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  categoryId  String   @db.VarChar(255)
  category    Category @relation(fields: [categoryId], references: [id])
  platform    Platform?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tariffs   ProductTariff[]
  keys      ProductKey[]
  orders    Order[]
  reviews   Review[]
  favorites FavoriteProduct[]

  @@index([categoryId])
  @@index([slug])
  @@map("products")
}

model ProductTariff {
  id        String     @id @default(cuid()) @db.VarChar(255)
  productId String     @db.VarChar(255)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      TariffName
  days      Int
  price     Decimal    @db.Decimal(12, 2)
  createdAt DateTime   @default(now())

  keys   ProductKey[]
  orders Order[]

  @@index([productId])
  @@map("product_tariffs")
}

model ProductKey {
  id        String   @id @default(cuid()) @db.VarChar(255)
  productId String   @db.VarChar(255)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tariffId  String   @db.VarChar(255)
  tariff    ProductTariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  key       String   @db.VarChar(255)
  isUsed    Boolean  @default(false)
  orderId   String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([tariffId])
  @@index([orderId])
  @@map("product_keys")
}

model Order {
  id            String          @id @default(cuid()) @db.VarChar(255)
  userId        String          @db.VarChar(255)
  user          User            @relation(fields: [userId], references: [id])
  productId     String          @db.VarChar(255)
  product       Product         @relation(fields: [productId], references: [id])
  tariffId      String?         @db.VarChar(255)
  tariff        ProductTariff?  @relation(fields: [tariffId], references: [id])
  totalPrice    Decimal         @db.Decimal(12, 2)
  status        OrderStatus     @default(CREATED)
  paymentMethod String?         @db.VarChar(255)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  balanceTransactions BalanceTransaction[]
  payments            Payment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
  @@map("orders")
}

model BalanceTransaction {
  id             String                  @id @default(cuid()) @db.VarChar(255)
  userId         String                  @db.VarChar(255)
  user           User                    @relation(fields: [userId], references: [id])
  amount         Decimal                 @db.Decimal(12, 2)
  type           BalanceTransactionType
  description    String?                 @db.Text
  relatedUserId  String?                 @db.VarChar(255)
  relatedUser    User?                   @relation("TransferSent", fields: [relatedUserId], references: [id])
  orderId        String?                 @db.VarChar(255)
  order          Order?                  @relation(fields: [orderId], references: [id])
  createdAt      DateTime                @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([type])
  @@map("balance_transactions")
}

model PaymentMethod {
  id        String   @id @default(cuid()) @db.VarChar(255)
  name      String   @db.VarChar(255)
  code      String   @unique @db.VarChar(255)
  isActive  Boolean  @default(true)
  config    Json     @default("{}")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  payments Payment[]

  @@map("payment_methods")
}

model Payment {
  id         String        @id @default(cuid()) @db.VarChar(255)
  userId     String        @db.VarChar(255)
  user       User          @relation(fields: [userId], references: [id])
  orderId    String?       @db.VarChar(255)
  order      Order?        @relation(fields: [orderId], references: [id])
  amount     Decimal       @db.Decimal(12, 2)
  methodId   String        @db.VarChar(255)
  method     PaymentMethod @relation(fields: [methodId], references: [id])
  status     PaymentStatus @default(PENDING)
  externalId String?       @db.VarChar(255)
  createdAt  DateTime      @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model Referral {
  id         String   @id @default(cuid()) @db.VarChar(255)
  referrerId String   @db.VarChar(255)
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId String   @unique @db.VarChar(255)
  referred   User     @relation("Referred", fields: [referredId], references: [id])
  createdAt  DateTime @default(now())

  transactions ReferralTransaction[]

  @@index([referrerId])
  @@map("referrals")
}

model ReferralTransaction {
  id                  String   @id @default(cuid()) @db.VarChar(255)
  referralId          String   @db.VarChar(255)
  referral            Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  amount              Decimal  @db.Decimal(12, 2)
  fromPurchaseOrderId String?  @db.VarChar(255)
  createdAt           DateTime @default(now())

  @@index([referralId])
  @@map("referral_transactions")
}

model Review {
  id         String   @id @default(cuid()) @db.VarChar(255)
  userId     String   @db.VarChar(255)
  user       User     @relation(fields: [userId], references: [id])
  productId  String?  @db.VarChar(255)
  product    Product? @relation(fields: [productId], references: [id])
  rating     Int
  text       String?  @db.Text
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([productId])
  @@map("reviews")
}

model SupportTicket {
  id        String             @id @default(cuid()) @db.VarChar(255)
  userId    String             @db.VarChar(255)
  user      User               @relation(fields: [userId], references: [id])
  subject   String             @db.VarChar(255)
  status    SupportTicketStatus @default(OPEN)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  messages TicketMessage[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model TicketMessage {
  id        String   @id @default(cuid()) @db.VarChar(255)
  ticketId  String   @db.VarChar(255)
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?  @db.VarChar(255)
  user      User?    @relation(fields: [userId], references: [id])
  isAdmin   Boolean  @default(false)
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

model CheatStatus {
  id        String         @id @default(cuid()) @db.VarChar(255)
  gameName  String         @db.VarChar(255)
  cheatName String         @db.VarChar(255)
  platform  String?        @db.VarChar(255)
  status    CheatStatusEnum
  updatedAt DateTime       @updatedAt

  @@index([gameName])
  @@map("cheat_statuses")
}

model News {
  id          String   @id @default(cuid()) @db.VarChar(255)
  title       String   @db.VarChar(255)
  content     String   @db.Text
  image       String?  @db.VarChar(255)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("news")
}

model Banner {
  id        String   @id @default(cuid()) @db.VarChar(255)
  title     String   @db.VarChar(255)
  imageUrl  String   @db.VarChar(255)
  linkUrl   String?  @db.VarChar(255)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("banners")
}

model FavoriteProduct {
  id        String   @id @default(cuid()) @db.VarChar(255)
  userId    String   @db.VarChar(255)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @db.VarChar(255)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("favorite_products")
}

model AuditLog {
  id        String   @id @default(cuid()) @db.VarChar(255)
  userId    String?  @db.VarChar(255)
  user      User?    @relation(fields: [userId], references: [id])
  action    String   @db.VarChar(255)
  details   Json?
  ip        String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(cuid()) @db.VarChar(255)
  key       String   @unique @db.VarChar(255)
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
